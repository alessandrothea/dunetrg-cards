#include "standard_detsim_dunevd10kt_1x8x14_3view_30deg.fcl"


process_name: "detsim@loop_index@"

physics.simulate: [ @sequence::dunefd_vertdrift_detsim_tpc_only ]

# physics.producers.tpcrawdecoder.wcls_main.structs.process_tpc_index: @loop_index@
# physics.producers.tpcrawdecoder.wcls_main.outputers: [
#             "wclsDepoFluxWriter:postdrift",
