#         ]
# physics.producers.tpcrawdecoder.wcls_main.params.process_mode: "single-sim-sp"
physics.producers.tpcrawdecoder: @local::dune10kt_dunefd_vertdrift_1x8x14_3view_30deg_sim_nfsp_singledigits


physics.filters: {
    hydrafilter:
    {
      module_type: HydraFilter
      tpcset_id: @loop_index@
    }
}

physics.simulate : [
    "hydrafilter",
    @sequence::physics.simulate
]

